# ------------------------------------------------------------------
# Environment variables template. Copy to `.env.local` for local dev.
# NEVER commit real secrets. `.env.local` is gitignored by default.
# ------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, robots, OG tags).
# No trailing slash. Production: https://ahmedmoussa.tech
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Contact form email delivery (optional) ----------------------
# If these are NOT set, the contact form still works: submissions are
# validated and logged server-side (see src/lib/email.ts). Set all three
# to enable real delivery via Resend (https://resend.com).

# Resend API key (server-only; never exposed to the browser).
RESEND_API_KEY=

# Address that receives contact submissions.
CONTACT_TO_EMAIL=

# Verified sender address on your Resend domain.
# Example: "Portfolio <contact@ahmedmoussa.tech>"
CONTACT_FROM_EMAIL=
